# =========================
# api.py（支持多模型+多collection）
# =========================

from http.server import BaseHTTPRequestHandler, HTTPServer
import json
import traceback

from retriever import retrieve
from reranker import rerank
from llm import generate_answer


class RAGHandler(BaseHTTPRequestHandler):

    def _send(self, data, code=200):
        self.send_response(code)
        self.send_header("Content-type", "application/json; charset=utf-8")
        self.end_headers()
        self.wfile.write(json.dumps(data, ensure_ascii=False).encode('utf-8'))

    def do_POST(self):
        # 1. 路径校验
        if self.path != "/rag/query":
            self._send({"error": "Not found"}, 404)
            return

        # 2. 读取并解码请求体
        length = int(self.headers.get("Content-Length", 0))
        raw_body = self.rfile.read(length)
        
        try:
            body_str = raw_body.decode('utf-8')
            data = json.loads(body_str)
            
            query = data.get("query")
            model = data.get("model", "text2vec")
            biz = data.get("biz", "cdn")

            print(f"--- 收到新请求 ---")
            print(f"Query: {query}")

            # 3. RAG 核心逻辑
            # A. 检索
            docs = retrieve(query, model=model, biz=biz)
            
            # B. 重排序 (在这里传入阈值，建议先设为 0.35)
            # 注意：请确保你的 reranker.py 里的 rerank 函数支持 threshold 参数
            # 或者你在 reranker.py 内部已经写好了过滤逻辑
            docs = rerank(query, docs) 

            # --- 新增阈值逻辑判断 ---
            # --- 拦截与结果展示逻辑 ---
            if not docs:
                answer = "❌ 匹配度太低（低于阈值），重排序后没有保留任何文档。"
                print(f"⚠️ 匹配度太低，已拦截。")
            else:
                # --- 修改点：不接 LLM，直接手动拼接排名结果 ---
                print(f"✅ 重排序完成，保留了 {len(docs)} 条结果。跳过 LLM。")
                
                # 构造一个展示排名的列表头
                result_list = [f"🔍 以下是为您找到的相关文档（按重排序得分排列）："]
                
                for i, d in enumerate(docs):
                    # 获取分数（假设你的 reranker 把分数存在 metadata['relevance_score'] 里）
                    score = d.metadata.get("relevance_score", "N/A")
                    # 取内容的前 100 个字做摘要预览
                    content_preview = d.page_content[:100].replace('\n', ' ')
                    
                    result_list.append(f"{i+1}. [得分: {score}] {content_preview}...")
                
                # 将列表转成带换行的字符串，作为“回答”返回给 UI
                answer = "\n\n".join(result_list)

            # --- C. generate_answer(query, docs) 这行暂时注销掉 ---
            # answer = generate_answer(query, docs)

            # 4. 格式化数据
            formatted_sources = []
            for d in docs:
                formatted_sources.append({
                    "content": d.page_content if hasattr(d, 'page_content') else str(d),
                    "metadata": d.metadata if hasattr(d, 'metadata') else {}
                })

            # 5. 发送响应
            self._send({
                "query": query,
                "model": model,
                "biz": biz,
                "answer": answer,
                "sources": formatted_sources
            })
            print(f"--- 回答发送成功 ---")

        except Exception as e:
            import traceback
            traceback.print_exc()
            self._send({"error": str(e)}, 500)


def run():
    server = HTTPServer(("", 8001), RAGHandler)
    print("RAG API running on 8001...")
    server.serve_forever()


if __name__ == "__main__":
    run()