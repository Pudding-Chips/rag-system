{
  "doc_title": "PolestarCloud API Documentation",
  "version": "1.0",
  "getting_started": {
    "token_url": "https://console.polestarcloud.com/user/setting",
    "login_restriction_url": "https://console.polestarcloud.com/user/setting",
    "environment_variables": {
      "api_url": "{{POLESTAR_API_URL}}",
      "api_token": "{{POLESTAR_TOKEN}}"
    },
    "security_note": "永远不要把你的API token告诉给任何人，如果不小心泄露了API key，请立刻删除此Key, 并可以另外生产新的Key。"
  },
  "common_definitions": {
    "headers": [
      {
        "field": "polestar-token",
        "type": "string",
        "required": true,
        "description": "API密钥",
        "note": "每个API请求都需要带上polestar-token请求头字段，值为后台生成的token"
      }
    ],
    "pagination_request": [
      { "field": "page", "type": "int", "required": true, "description": "默认值为1" },
      { "field": "pageSize", "type": "int", "required": true, "description": "默认值为10" },
      { "field": "desc", "type": "int", "required": true, "description": "是否倒序，1为倒序，0为顺序，默认值为0" },
      { "field": "sort", "type": "string", "required": false, "description": "排序字段" }
    ],
    "common_response": [
      { "field": "code", "type": "int", "description": "状态码(200正常)" },
      { "field": "msg", "type": "string", "description": "success(正常), fail(失败)" },
      { "field": "data", "type": "any", "description": "对象,数组,数字,字符串" }
    ],
    "pagination_response": [
      { "field": "number", "type": "int", "description": "当前第几页" },
      { "field": "size", "type": "int", "description": "当前页大小" },
      { "field": "totalPages", "type": "int", "description": "总页数" },
      { "field": "numberOfElements", "type": "int", "description": "当前页条数" },
      { "field": "totalElements", "type": "int", "description": "总数量" },
      { "field": "content", "type": "array", "description": "列表内容" }
    ]
  },
  "modules": {
    "3.1_site_basic_operations": {
      "module_name": "站点基础操作",
      "apis": [
        {
          "id": "3.1.1",
          "name": "站点列表",
          "path": "/api/site/page",
          "method": "POST",
          "curl_example": "curl \"{{POLESTAR_API_URL}}/api/site/page\" -H \"content-type: application/json\" -H \"polestar-token: {{POLESTAR_TOKEN}}\" --data-raw '{\"keyWord\":\"\",\"searchPage\":{\"desc\":1,\"page\":1,\"pageSize\":5,\"sort\":\"\"},\"type\":\"cname,normal,ip\"}'",
          "request_body": [
            { "field": "keyWord", "type": "string", "required": false, "description": "关键字查询" },
            { "field": "searchPage", "type": "object", "required": true, "description": "分页请求体(参考<公共请求体>)" },
            { "field": "type", "type": "string", "required": true, "description": "站点类型(cname:MNC站点, normal:普通站点, port:4层转发站点), 可以使用逗号查询多种类型" }
          ],
          "response_body_content_fields": [
            { "field": "id", "type": "int", "description": "站点ID" },
            { "field": "name", "type": "string", "description": "站点名称" },
            { "field": "uniqueName", "type": "string", "description": "CNAME前缀" },
            { "field": "globalHost", "type": "string", "description": "CNAME后缀" },
            { "field": "type", "type": "string", "description": "站点类型(cname:MNC站点,normal:普通站点,port:端口转发)" },
            { "field": "status", "type": "int", "description": "状态(1:启用,-1禁用)" },
            { "field": "customerId", "type": "int", "description": "客户ID" },
            { "field": "customerName", "type": "string", "description": "客户名称" },
            { "field": "upstream", "type": "string", "description": "源点" },
            { "field": "upstreamProtocol", "type": "string", "description": "回源协议(http" },
            { "field": "upstreamBalance", "type": "string", "description": "负载方式(ip_hash:根据IP, poll:轮训, backup:备用机机制)" },
            { "field": "upstreamPortFlag", "type": "int", "description": "端口回源(1:启用, 0:禁用)，开启后会忽略源点" },
            { "field": "description", "type": "string", "description": "站点描述" }
          ]
        },
        {
          "id": "3.1.2",
          "name": "获取站点",
          "path": "/api/site/find-by-id",
          "method": "GET",
          "curl_example": "curl \"{{POLESTAR_API_URL}}/api/site/find-by-id?id=1\" -H \"content-type: application/json\" -H \"polestar-token: {{POLESTAR_TOKEN}}\"",
          "request_params": [
            { "field": "id", "type": "int", "required": true, "description": "站点ID" }
          ],
          "response_body_data_fields": [
            { "field": "id", "type": "int", "description": "站点ID" },
            { "field": "name", "type": "string", "description": "站点名称" },
            { "field": "uniqueName", "type": "string", "description": "CNAME前缀" },
            { "field": "globalHost", "type": "string", "description": "CNAME后缀" },
            { "field": "type", "type": "string", "description": "站点类型(cname:MNC站点,normal:普通站点,port:端口转发)" },
            { "field": "status", "type": "int", "description": "状态(1:启用,-1禁用)" },
            { "field": "customerId", "type": "int", "description": "客户ID" },
            { "field": "customerName", "type": "string", "description": "客户名称" },
            { "field": "upstream", "type": "string", "description": "源点" },
            { "field": "upstreamProtocol", "type": "string", "description": "回源协议(http|https)，如果开启端口回源会忽略该设置" },
            { "field": "upstreamBalance", "type": "string", "description": "负载方式(ip_hash:根据IP, poll:轮训, backup:备用机机制)" },
            { "field": "upstreamPortFlag", "type": "int", "description": "端口回源(1:启用, 0:禁用)，开启后会忽略源点" },
            { "field": "description", "type": "string", "description": "站点描述" }
          ]
        },
        {
          "id": "3.1.3",
          "name": "新增站点",
          "path": "/api/site/create",
          "method": "PUT",
          "curl_example": "curl \"{{POLESTAR_API_URL}}/api/site/create\" -X \"PUT\" -H \"content-type: application/json\" -H \"polestar-token: {{POLESTAR_TOKEN}}\" --data-raw '{\"name\":\"example\",\"type\":\"normal\",\"upstreamList\":[{\"host\":\"1.1.1.1\",\"port\":\"80\"}],\"upstreamBalance\":\"ip_hash\",\"upstreamPortFlag\":0,\"upstreamProtocol\":\"http\"}'",
          "request_body": [
            { "field": "name", "type": "string", "required": false, "description": "站点名称" },
            { "field": "type", "type": "string", "required": true, "description": "站点类型(normal:普通站点,cname:MNC站点,port:端口转发)" },
            { "field": "upstreamList", "type": "array", "required": true, "description": "源点列表(host:源点IP或者CNAME, port:源点端口)" },
            { "field": "upstreamBalance", "type": "string", "required": true, "description": "负载方式(ip_hash:根据IP, poll:轮训, backup:备用机机制)" },
            { "field": "upstreamPortFlag", "type": "int", "required": false, "description": "默认值为0, 按端口回源" },
            { "field": "upstreamProtocol", "type": "string", "required": true, "description": "回源协议(http\\https), 如果按端口回源会忽略该参数" }
          ]
        },
        {
          "id": "3.1.4",
          "name": "修改站点",
          "path": "/api/site/modify",
          "method": "PUT",
          "curl_example": "curl \"{{POLESTAR_API_URL}}/api/site/modify\" -X \"PUT\" -H \"content-type: application/json\" -H \"polestar-token: {{POLESTAR_TOKEN}}\" --data-raw '{\"id\":1,\"customerId\":1,\"name\":\"example\",\"description\":null,\"type\":\"normal\",\"upstreamList\":[{\"host\":\"1.1.1.1\",\"port\":80}],\"upstreamProtocol\":\"http\",\"upstreamPortFlag\":0,\"upstreamBalance\":\"ip_hash\",\"certCount\":null,\"dnsConfId\":null}'",
          "request_body": [
            { "field": "id", "type": "int", "required": true, "description": "站点ID" },
            { "field": "name", "type": "string", "required": false, "description": "站点名称" },
            { "field": "type", "type": "string", "required": true, "description": "站点类型(normal:普通站点,cname:MNC站点)" },
            { "field": "upstreamList", "type": "array", "required": true, "description": "源点请求体列表" },
            { "field": "upstreamBalance", "type": "string", "required": true, "description": "负载方式(ip_hash:根据IP, poll:轮训, backup:备用机机制)" },
            { "field": "upstreamPortFlag", "type": "int", "required": false, "description": "是否根据端口回源(1:启用,0:禁用)" },
            { "field": "upstreamProtocol", "type": "string", "required": true, "description": "回源协议(http|https), 如果开启端口回源会忽略该设置" },
            { "field": "description", "type": "string", "required": false, "description": "站点描述" }
          ],
          "response_body_data_fields": [
            { "field": "id", "type": "int", "description": "站点ID" },
            { "field": "name", "type": "string", "description": "站点名称" },
            { "field": "uniqueName", "type": "string", "description": "CNAME前缀" },
            { "field": "type", "type": "string", "description": "站点类型(cname:MNC站点,normal:普通站点,port:端口转发)" },
            { "field": "status", "type": "int", "description": "状态(1:启用,-1禁用)" },
            { "field": "customerId", "type": "int", "description": "客户ID" },
            { "field": "customerName", "type": "string", "description": "客户名称" },
            { "field": "upstream", "type": "string", "description": "源点" },
            { "field": "upstreamProtocol", "type": "string", "description": "回源协议(http|https)，如果开启端口回源会忽略该设置" },
            { "field": "upstreamBalance", "type": "string", "description": "负载方式(ip_hash:根据IP, poll:轮训, backup:备用机机制)" },
            { "field": "upstreamPortFlag", "type": "int", "description": "端口回源(1:启用, 0:禁用)，开启后会忽略源点" },
            { "field": "description", "type": "string", "description": "站点描述" }
          ]
        },
        {
          "id": "3.1.5",
          "name": "删除站点",
          "path": "/api/site/delete",
          "method": "DELETE",
          "curl_example": "curl \"{{POLESTAR_API_URL}}/api/site/delete?id=1\" -X \"DELETE\" -H \"content-type: application/json\" -H \"polestar-token: {{POLESTAR_TOKEN}}\"",
          "request_params": [
            { "field": "id", "type": "int", "required": true, "description": "站点ID" }
          ]
        },
        {
          "id": "3.1.6",
          "name": "禁用站点",
          "path": "/api/site/disable",
          "method": "PUT",
          "curl_example": "curl \"{{POLESTAR_API_URL}}/api/site/disable?id=1\" -X \"PUT\" -H \"content-type: application/json\" -H \"polestar-token: {{POLESTAR_TOKEN}}\"",
          "request_params": [
            { "field": "id", "type": "int", "required": true, "description": "站点ID" }
          ]
        },
        {
          "id": "3.1.7",
          "name": "启用站点",
          "path": "/api/site/enable",
          "method": "PUT",
          "curl_example": "curl \"{{POLESTAR_API_URL}}/api/site/enable?id=1\" -X \"PUT\" -H \"content-type: application/json\" -H \"polestar-token: {{POLESTAR_TOKEN}}\"",
          "request_params": [
            { "field": "id", "type": "int", "required": true, "description": "站点ID" }
          ]
        },
        {
          "id": "3.1.8",
          "name": "导出所选站点域名列表文件",
          "path": "/api/domain/export-list",
          "method": "POST",
          "curl_example": "curl \"{{POLESTAR_API_URL}}/api/domain/export-list\" -H \"content-type: application/json\" -H \"polestar-token: {{POLESTAR_TOKEN}}\" --data-raw '[1]'",
          "request_params": [
            { "field": "data-raw", "type": "int", "required": true, "description": "请直接输入站点ID" }
          ]
        }
      ]
    }
  }
}