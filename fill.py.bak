# =========================
# fill_db.py（支持多模型+多collection）
# =========================

import os
import hashlib
from langchain_community.document_loaders import PyPDFLoader
from langchain_text_splitters import RecursiveCharacterTextSplitter

from db import get_collection
from embed import embed_texts
from config import DEFAULT_MODEL, DEFAULT_BIZ

BASE_DIR = os.path.dirname(os.path.abspath(__file__))
DATA_PATH = os.path.join(BASE_DIR, "data")

MODEL_NAME = DEFAULT_MODEL
BIZ = DEFAULT_BIZ

collection = get_collection(BIZ, MODEL_NAME)

text_splitter = RecursiveCharacterTextSplitter(
    chunk_size=400,
    chunk_overlap=50,
    separators=["\n\n", "\n", "。", "！", "？", ".", "!", "?", " ", ""]
)


def get_file_hash(file_path):
    hasher = hashlib.md5()
    with open(file_path, 'rb') as f:
        for chunk in iter(lambda: f.read(4096), b""):
            hasher.update(chunk)
    return hasher.hexdigest()


def clean_text(text):
    text = text.strip()
    if len(text) < 50:
        return None
    if all(c in " \n\t-_=+*/\\|" for c in text):
        return None
    return text


for file_name in os.listdir(DATA_PATH):
    if not file_name.endswith(".pdf"):
        continue

    file_path = os.path.join(DATA_PATH, file_name)
    file_hash = get_file_hash(file_path)

    loader = PyPDFLoader(file_path)
    raw_documents = loader.load()[0:10]

    chunks = text_splitter.split_documents(raw_documents)

    docs, metas, ids = [], [], []

    for i, chunk in enumerate(chunks):
        text = clean_text(chunk.page_content)
        if not text:
            continue

        docs.append(text)
        ids.append(f"{file_name}_{file_hash[:8]}_{i}")

        meta = chunk.metadata or {}
        meta["source"] = file_name
        meta["chunk_index"] = i
        metas.append(meta)

        if len(docs) == 50:
            embs = embed_texts(docs, MODEL_NAME)
            collection.upsert(documents=docs, embeddings=embs.tolist(), metadatas=metas, ids=ids)
            docs, metas, ids = [], [], []

    if docs:
        embs = embed_texts(docs, MODEL_NAME)
        collection.upsert(documents=docs, embeddings=embs.tolist(), metadatas=metas, ids=ids)

print("✅ 数据写入完成")