# =========================
# retriever.py（支持 multi-query + rewrite）
# =========================

from db import get_collection
from embed import embed_texts
import requests

OLLAMA_URL = "http://localhost:11434/api/generate"
LLM_MODEL = "llama3"


def rewrite_query(query):
    """用LLM改写query（更适合检索）"""
    prompt = f"将这个问题改写成更适合搜索的形式：\n{query}\n只输出改写结果"

    try:
        res = requests.post(OLLAMA_URL, json={
            "model": LLM_MODEL,
            "prompt": prompt,
            "stream": False
        })
        return res.json().get("response", query).strip()
    except Exception:
        return query


def build_multi_queries(query):
    """多query扩展"""
    rewritten = rewrite_query(query)

    queries = list(set([
        query,
        rewritten,
        f"{query} 是什么",
        f"{query} 解决方法",
        f"{query} 原因"
    ]))

    return queries


def retrieve(query, model="text2vec", biz="cdn", n_results=5):
    collection = get_collection(biz, model)

    queries = build_multi_queries(query)

    all_docs = []

    for q in queries:
        query_emb = embed_texts([q], model)[0]

        results = collection.query(
            query_embeddings=[query_emb.tolist()],
            n_results=n_results,
            include=["documents", "metadatas"]
        )

        docs = results.get("documents", [[]])[0]
        metas = results.get("metadatas", [[]])[0]

        for i, d in enumerate(docs):
            all_docs.append({
                "content": d,
                "metadata": metas[i] if metas else {}
            })

    # 简单去重（按content）
    seen = set()
    unique_docs = []

    for d in all_docs:
        if d["content"] not in seen:
            seen.add(d["content"])
            unique_docs.append(d)

    return unique_docs
